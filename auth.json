root url: `/api/v1/auth`
response main format :`{  message:"string",
data:{}
}`
1. register:
POST: `/register`
 - payload: `{
   "first_name": "string",
   "last_name": "string",
   "email": "string",
   "phone_number": "string",
   "password": "string",
   "confirm_password": "string"
 }`
 - respose: `{
    message:"string" `error_code`,
    data:{}
 }`

2. login:
POST: `/login`
 - payload: `{
   "email":"string",
   "password":"string"
 }`
 - response: `{
    message:"string" `error_code`,
    data:{
      token:""
      refresh_token:""
    }
 }`
3. profile:
GET: `/profile`
 - payload: `{}`
 - response: `{
    message:"string" `error_code`,
    data:{
      "first_name": "string",
      "last_name": "string",
      "email": "string",
      "phone_number": "string",
    }
 }`

4. profile:
PUT: `/profile`
 - payload: `{
"first_name": "string",
"last_name": "string",
"email": "string",
"phone_number": "string",}`
 - response: `{
    message:"string" `error_code`,
    data:{}
 }`

5.  delete account
DELETE: `/profile`
 - payload: `{}`
 - response: `{
    message:"string" `error_code`,
    data:{}
 }`

6. logout
POST: `/logout`
 - payload: `{}`
 - response: `{
    message:"string" `error_code`,
    data:{}
 }`
7. forgot password
POST: `/forgotPassword`
 - payload: `{
   "email": "string"
 }`
 - response: `{
    message:"string" `error_code`,
    data:{}
 }`
8. reset password
POST: `/resetPassword`
 - payload: `{
   "email": "string",
   "password": "string",
   "confirm_password": "string"
 }`
 - response: `{
    message:"string" `error_code`,
    data:{}
 }`
9. change password
POST: `/changePassword`
 - payload: `{
   "old_password": "string",
   "new_password": "string",
   "confirm_password": "string"
 }`
 - response: `{
    message:"string" `error_code`,
    data:{}
 }`
10. verify email
POST: `/verifyEmail`
 - payload: `{
   "code": "string"
 }`
 - response: `{
    message:"string" `error_code`,
    data:{}
 }`
11. resend verification email
POST: `/resendVerificationEmail`
 - payload: `{}`
 - response: `{
    message:"string" `error_code`,
    data:{}
 }`
12. refresh token
POST: `/refreshToken`
 - payload: `{
   "refresh_token": "string"
 }`
 - response: `{
    message:"string" `error_code`,
    data:{
      token:"",
      refresh_token:""
    }
 }
